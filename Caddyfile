:80 {
  root * /usr/share/caddy
  encode zstd gzip

  # Vite fingerprints files in /assets, so they can be cached aggressively.
  @static_assets path /assets/*
  header @static_assets Cache-Control "public, max-age=31536000, immutable"

  # index.html should stay fresh so new deployments are picked up quickly.
  @html path /index.html
  header @html Cache-Control "no-store"

  try_files {path} /index.html
  file_server
}
