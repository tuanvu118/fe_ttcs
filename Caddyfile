:80 {
  root * /usr/share/caddy
  encode zstd gzip

  # Vite fingerprints files in /assets, so they can be cached aggressively.
  @static_assets path /assets/*
  header @static_assets Cache-Control "public, max-age=31536000, immutable"

  # All other routes (SPA HTML) should stay fresh
  @not_static {
    not path /assets/*
  }
  header @not_static Cache-Control "no-store, no-cache, must-revalidate"

  try_files {path} /index.html
  file_server
}
